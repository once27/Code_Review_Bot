# ---------------------------------------------------------------------------
.coverage
htmlcov/
.pytest_cache/
.tox/

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
logs/

# ---------------------------------------------------------------------------
