__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# ---------------------------------------------------------------------------
# Virtual Environment
# ---------------------------------------------------------------------------
venv/
.venv/
ENV/
env/

# ---------------------------------------------------------------------------
# Environment Variables (secrets)
# ---------------------------------------------------------------------------
.env

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# ChromaDB (local vector store)
# ---------------------------------------------------------------------------
chroma_db/

# ---------------------------------------------------------------------------
# Celery
# ---------------------------------------------------------------------------
celerybeat-schedule
celerybeat.pid

# ---------------------------------------------------------------------------
# Alembic
# ---------------------------------------------------------------------------
alembic/versions/__pycache__/

# ---------------------------------------------------------------------------
