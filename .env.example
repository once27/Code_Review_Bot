# ============================================================================
# AI Code Review Bot — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control — only .env.example is safe to commit.
# ============================================================================

# ---------------------------------------------------------------------------
# GitHub Configuration
# ---------------------------------------------------------------------------
# Webhook secret used to validate incoming GitHub webhook payloads (HMAC-SHA256)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# GitHub App credentials (created in GitHub → Settings → Developer Settings → GitHub Apps)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=

# Personal Access Token (alternative to GitHub App for development)
GITHUB_TOKEN=your_github_token_here

# ---------------------------------------------------------------------------
# LLM / AI Configuration
# ---------------------------------------------------------------------------
# OpenAI API key for GPT-4o-mini (or other models via LangChain)
OPENAI_API_KEY=your_openai_api_key_here

# Model to use (can be swapped without code changes)
LLM_MODEL=gpt-4o-mini

# Temperature for LLM responses (0 = deterministic, 1 = creative)
LLM_TEMPERATURE=0

# ---------------------------------------------------------------------------
# Database Configuration
# ---------------------------------------------------------------------------
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/codereviewbot

# ---------------------------------------------------------------------------
# Redis Configuration
# ---------------------------------------------------------------------------
# Used as Celery broker and result backend, plus response caching
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# Application Settings
# ---------------------------------------------------------------------------
# Environment: development / staging / production
APP_ENV=development

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# Maximum number of review comments per PR (safety cap)
MAX_COMMENTS_PER_PR=20

# Minimum severity to post: suggestion / warning / critical
REVIEW_THRESHOLD=suggestion
